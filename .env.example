# Authentication
AUTH_SECRET=replace-with-a-long-random-string
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
OWNER_EMAIL=you@example.com
OUTREACH_SENDER_NAME=Your first name

# Turso / Drizzle
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=

# Lead discovery
GOOGLE_PLACES_API_KEY=
# Estimated cost per Places search, expressed in the campaign budget's minor unit.
GOOGLE_PLACES_ESTIMATED_REQUEST_MINOR=0

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_DAILY_LIMIT=30

# Vercel cron authentication
CRON_SECRET=replace-with-a-different-long-random-string

# Local UI preview only. Keep false in Vercel.
DEMO_MODE=false
